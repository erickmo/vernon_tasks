{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "outDir": "./.tsbuild-node",
    "declarationDir": "./.tsbuild-node",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "playwright.config.ts"]
}
